@startuml development_roadmap
start
partition "Data Selection and Preprocessing" {
    :Exploratory Analysis;
    ' Put notes immediately AFTER the activity step
    note left
        **Input:**
        - /path/to/dataset
    end note
    note right
        **Output:**
        - Signal-Background ratio
        - Distribution histograms
    end note
}
partition "Tuning Process" {
    :Arquitecture definition;
    note left
        **Input:**
        - Layers
        - Number of neurons
    end note
    partition "Training Step" {
        fork
            partition "PTQ" {
                :Floating point training;
                :Quantize model;
            }
        fork again
            partition "QAT" {
                :Train quantized model;

            }
        end fork
    }
    note right
        **Output:**
        - Model files
        - Training history
    end note
    :Compare performance difference;
    note left
        **Input:**
        - Models
            - No quantization
            - PTQ
            - QAT
        - Dataset
    end note
    note right
        **Output:**
        - Metrics: ROC AUC, SP, Pd, Fr
    end note
}
partition "FPGA Implementation" {
    fork
        :Implementation with hls4ml;
        note left
            **Input:**
            - Model files
            - HLS4ML config
        end note
        note right
            **Output:**
            - Implementation Code
        end note
    fork again
        :Implementation with System Verilog;
        note right
            **Output:**
            - Implementation Code
        end note
    endfork
    :Compare FPGA models;
    note left
        **Input:**
        - Implementation files
    end note
    note right
        **Output:**
        - Latency
        - Resource usage
        - Power Consumption
        - Performance metrics
    end note
}

stop
@enduml